{% extends "layout.njk" %}
{% import "macros.njk" as m %}
{% set toc = [
  ["text", "Text inputs"],
  ["labels", "Labels"],
  ["select", "Select"],
  ["choice", "Checkbox and radio"],
  ["helper", "Helper text"],
  ["validation", "Validation"],
  ["disabled", "Disabled"],
  ["fieldset", "Fieldsets"],
  ["kitchen-sink", "Kitchen sink"]
] %}

{% block content %}
<h1>Forms</h1>
<p>Wrap a control in a <code>&lt;label&gt;</code> and it is styled. No classes for the common cases.</p>

<section id="text">
  <h2>Text inputs</h2>
  {% call m.demo("form-text") %}
<label>Name <input type="text" placeholder="Jane Doe" /></label>
<label>Email <input type="email" placeholder="jane@example.com" /></label>
<label>Password <input type="password" placeholder="••••••••" /></label>
<label>Phone <input type="tel" placeholder="503-555-0100" /></label>
<label>Website <input type="url" placeholder="https://example.com" /></label>
<label>Search <input type="search" placeholder="Search" /></label>
<label>Quantity <input type="number" value="1" min="0" /></label>
  {% endcall %}
</section>

<section id="labels">
  <h2>Label structure</h2>
  <p>
    A bare text node in the label works. Wrapping it in <code>&lt;p&gt;</code> gives you a block you
    can style, and it is what the invalid-state selector keys off of.
  </p>
  {% call m.demo("form-labels") %}
<label>
  <p>Birth date</p>
  <input type="date" />
</label>
<label>
  <p>Reminder</p>
  <input type="time" />
</label>
  {% endcall %}
  <p>
    <small>
      Date, time, and select controls get an icon from <code>--icon-calendar</code>,
      <code>--icon-clock</code>, and <code>--icon-chevron</code>. Each is an inline base64 SVG that
      swaps between a black and white stroke with the color scheme. Size and inset come from
      <code>--icon-width</code> and <code>--icon-position</code>.
    </small>
  </p>
</section>

<section id="select">
  <h2>Select and textarea</h2>
  {% call m.demo("form-select") %}
<label>
  Role
  <select>
    <option value="">Select a role</option>
    <option>Developer</option>
    <option>Designer</option>
    <option>Project manager</option>
  </select>
</label>

<label>
  Bio
  <textarea placeholder="Tell us about yourself"></textarea>
</label>
  {% endcall %}
</section>

<section id="choice">
  <h2>Checkboxes and radios</h2>
  <p>Put the control inside the label, before the text.</p>
  {% call m.demo("form-choice") %}
<label><input type="checkbox" /> Subscribe to updates</label>
<label><input type="checkbox" checked /> Already subscribed</label>

<label><input type="radio" name="plan" checked /> Free plan</label>
<label><input type="radio" name="plan" /> Pro plan</label>
  {% endcall %}
</section>

<section id="helper">
  <h2>Helper text</h2>
  <p>
    A <code>&lt;small&gt;</code> immediately after a control collapses the control's bottom margin
    and becomes helper text at <code>--text-lc-3</code>.
  </p>
  {% call m.demo("form-helper") %}
<label>
  Username
  <input type="text" />
  <small>Letters, numbers, and underscores only.</small>
</label>
  {% endcall %}
</section>

<section id="validation">
  <h2>Validation</h2>
  <p>
    Set <code>aria-invalid="true"</code> on the control. The label's <code>&lt;p&gt;</code> and the
    control both pick up <code>--error-color</code>. Pair it with <code>small.error</code>.
  </p>
  {% call m.demo("form-validation") %}
<label>
  <p>Username</p>
  <input type="text" value="taken_username" aria-invalid="true" />
  <small class="error">This username is already taken.</small>
</label>

<label>
  <p>Password</p>
  <input type="password" aria-invalid="true" />
  <small class="error">Must be at least 8 characters.</small>
</label>
  {% endcall %}
</section>

<section id="disabled">
  <h2>Disabled and readonly</h2>
  {% call m.demo("form-disabled") %}
<label>
  Locked field
  <input type="text" value="Cannot edit" disabled />
</label>
<label>
  Read only
  <input type="text" value="Can select, cannot edit" readonly />
</label>
  {% endcall %}
</section>

<section id="fieldset">
  <h2>Fieldsets</h2>
  {% call m.demo("form-fieldset") %}
<fieldset>
  <legend>Contact info</legend>
  <label>Name <input type="text" /></label>
  <label>Email <input type="email" /></label>
</fieldset>
  {% endcall %}
</section>

<section id="kitchen-sink">
  <h2>Kitchen sink</h2>
  <p>Everything above, in one realistic form.</p>
  {% call m.demo("form-kitchen-sink") %}
<form>
  <fieldset>
    <legend>Contact info</legend>
    <label>Name <input type="text" placeholder="Jane Doe" /></label>
    <label>Email <input type="email" placeholder="jane@example.com" /></label>
    <label>
      <p>Phone</p>
      <input type="tel" aria-invalid="true" />
      <small class="error">Enter a valid phone number.</small>
    </label>
  </fieldset>

  <fieldset>
    <legend>Preferences</legend>
    <label>
      Favorite language
      <select>
        <option>TypeScript</option>
        <option>Go</option>
        <option>CSS</option>
      </select>
    </label>
    <label><input type="checkbox" /> Send me updates</label>
    <label><input type="radio" name="tier" checked /> Free</label>
    <label><input type="radio" name="tier" /> Pro</label>
  </fieldset>

  <label>
    Message
    <textarea></textarea>
    <small>Markdown is supported.</small>
  </label>

  <div class="flex">
    <button type="reset" class="secondary">Reset</button>
    <button type="submit">Submit</button>
  </div>
</form>
  {% endcall %}
</section>
{% endblock %}
