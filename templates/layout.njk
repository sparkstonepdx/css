{% set navItems = [
  ["index", "Home"],
  ["colors", "Colors"],
  ["typography", "Typography"],
  ["buttons", "Buttons"],
  ["forms", "Forms"],
  ["containers", "Containers"],
  ["layout", "Layout"],
  ["customizing", "Customizing"]
] %}
{% set current = title or "index" %}
<!DOCTYPE html>
<html lang="en" data-color-scheme="light">
  <head>
    <meta charset="UTF-8" />
    <title>{% if title %}{{ title | capitalize }} · {% endif %}@sparkstone/css</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="./theme.css" />
    <link rel="stylesheet" href="./docs.css" />
    <script src="./docs.js" type="module"></script>
  </head>
  <body>
    <header class="container-fluid site-header">
      <nav class="flex" style="align-items: center">
        <strong><a href="./index.html" class="semantic">@sparkstone/css</a></strong>
      </nav>
      <nav class="flex site-nav" style="flex-wrap: wrap">
        {% for item in navItems %}
          <a href="./{{ item[0] }}.html"{% if item[0] == current %} aria-current="page"{% endif %}>{{ item[1] }}</a>
        {% endfor %}
        <button id="theme-toggle" class="ghost" aria-label="Toggle color scheme">Dark</button>
      </nav>
    </header>

    <main class="container">
      {% if toc %}
        <nav class="toc" aria-label="On this page">
          <ul>
            {% for item in toc %}
              <li><a href="#{{ item[0] }}">{{ item[1] }}</a></li>
            {% endfor %}
          </ul>
        </nav>
      {% endif %}

      {% block content %}{% endblock %}

      <footer class="site-footer">
        <hr />
        <p>
          <small>
            <a href="https://www.npmjs.com/package/@sparkstone/css">npm</a> ·
            <a href="https://github.com/sparkstonepdx/css">GitHub</a> ·
            MIT
          </small>
        </p>
      </footer>
    </main>

    {% block scripts %}{% endblock %}
  </body>
</html>
